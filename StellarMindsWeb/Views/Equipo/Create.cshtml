@model StellarMindsWeb.Models.EquipoViewModel

@{
    ViewData["Title"] = "Nuevo equipo";
}

<h1>Nuevo equipo</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Create" method="post">
            @await Html.PartialAsync("_FormularioEquipo", Model)

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        // Muestra solo el fieldset del tipo elegido.
        (function () {
            var selector = document.getElementById('selectorTipo');
            if (!selector) return;
            var bloques = document.querySelectorAll('.bloque-tipo');

            function actualizar() {
                var tipo = selector.value;
                bloques.forEach(function (b) {
                    b.style.display = (b.getAttribute('data-tipo') === tipo) ? '' : 'none';
                });
            }

            selector.addEventListener('change', actualizar);
            actualizar();
        })();
    </script>
}
