@model DTOs.DTOs.EquipoDTO

@{
    ViewData["Title"] = "Eliminar equipo";
}

<h1>Eliminar equipo</h1>
<hr />

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<p>Confirma la eliminacion del siguiente equipo:</p>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Tipo</dt>
    <dd class="col-sm-9">@Model.TipoEquipo</dd>

    <dt class="col-sm-3">Marca</dt>
    <dd class="col-sm-9">@Model.Marca</dd>

    <dt class="col-sm-3">Modelo</dt>
    <dd class="col-sm-9">@Model.Modelo</dd>

    <dt class="col-sm-3">Stock</dt>
    <dd class="col-sm-9">@Model.Stock</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Confirmar eliminacion</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>
