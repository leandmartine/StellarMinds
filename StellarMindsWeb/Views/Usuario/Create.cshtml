@model StellarMindsWeb.Models.CrearUsuarioViewModel

@{
    ViewData["Title"] = "Crear usuario";
}

<h1>Crear usuario</h1>
<hr />

<div class="row">
    <div class="col-md-5">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-controller="Usuario" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <h5>Datos personales</h5>
            <div class="form-group mb-2">
                <label asp-for="NombreCompleto" class="control-label"></label>
                <input asp-for="NombreCompleto" class="form-control" />
                <span asp-validation-for="NombreCompleto" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Telefono" class="control-label"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Mail" class="control-label"></label>
                <input asp-for="Mail" class="form-control" type="email" />
                <span asp-validation-for="Mail" class="text-danger"></span>
            </div>

            <h5 class="mt-3">Dirección</h5>
            <div class="form-group mb-2">
                <label asp-for="Calle" class="control-label"></label>
                <input asp-for="Calle" class="form-control" />
                <span asp-validation-for="Calle" class="text-danger"></span>
            </div>
            <div class="row mb-2">
                <div class="col">
                    <label asp-for="Numero" class="control-label"></label>
                    <input asp-for="Numero" class="form-control" type="number" />
                    <span asp-validation-for="Numero" class="text-danger"></span>
                </div>
                <div class="col">
                    <label asp-for="Apartamento" class="control-label"></label>
                    <input asp-for="Apartamento" class="form-control" type="number" />
                    <span asp-validation-for="Apartamento" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Esquina" class="control-label"></label>
                <input asp-for="Esquina" class="form-control" />
                <span asp-validation-for="Esquina" class="text-danger"></span>
            </div>
            <div class="row mb-2">
                <div class="col">
                    <label asp-for="Departamento" class="control-label"></label>
                    <input asp-for="Departamento" class="form-control" />
                    <span asp-validation-for="Departamento" class="text-danger"></span>
                </div>
                <div class="col">
                    <label asp-for="Pais" class="control-label"></label>
                    <input asp-for="Pais" class="form-control" />
                    <span asp-validation-for="Pais" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-3">Cuenta</h5>
            <div class="form-group mb-2">
                <label asp-for="NombreUsuario" class="control-label"></label>
                <input asp-for="NombreUsuario" class="form-control" />
                <span asp-validation-for="NombreUsuario" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Contrasena" class="control-label"></label>
                <input asp-for="Contrasena" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Rol" class="control-label"></label>
                <select asp-for="Rol" class="form-control"
                        asp-items="Html.GetEnumSelectList<StellarMinds.Enums.RolDeUsuario>()">
                </select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
