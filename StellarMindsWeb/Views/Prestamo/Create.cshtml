@model StellarMindsWeb.Models.PrestamoViewModel
@using DTOs.DTOs

@{
    ViewData["Title"] = "Nuevo préstamo";
}

<h1>Nuevo préstamo</h1>
<hr />

@* Mensaje de éxito que viene de TempData luego de una alta exitosa *@
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Errores generales del servidor (reglas de negocio) *@
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @* Mostrar errores de validación del modelo *@
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            @* --- Socio --- *@
            <div class="mb-3">
                <label asp-for="SocioId" class="form-label fw-bold">Socio</label>
                <select asp-for="SocioId" class="form-select">
                    <option value="">-- Seleccione un socio --</option>
                    @foreach (var socio in Model.Socios)
                    {
                        <option value="@socio.Id">@socio.NombreCompleto.nombreCompleto (@socio.NombreUsuario)</option>
                    }
                </select>
                <span asp-validation-for="SocioId" class="text-danger"></span>
            </div>

            @* --- Fechas --- *@
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="FechaInicio" class="form-label fw-bold">Fecha de inicio</label>
                    <input asp-for="FechaInicio" class="form-control" type="date" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaFin" class="form-label fw-bold">Fecha de fin</label>
                    <input asp-for="FechaFin" class="form-control" type="date" />
                    <span asp-validation-for="FechaFin" class="text-danger"></span>
                </div>
            </div>

            @* --- Telescopio --- *@
            <div class="mb-3">
                <label asp-for="TelescopioId" class="form-label fw-bold">Telescopio</label>
                @*
                    RF04: al cambiar la selección, el JS llama al endpoint WebAPI
                    para verificar disponibilidad SIN enviar el formulario.
                *@
                <select asp-for="TelescopioId" class="form-select equipo-select" data-aviso="aviso-telescopio">
                    <option value="">-- Seleccione un telescopio --</option>
                    @foreach (var t in Model.Telescopios)
                    {
                        <option value="@t.Id">@t.Marca @t.Modelo — Stock: @t.Stock</option>
                    }
                </select>
                <div id="aviso-telescopio" class="mt-1"></div>
                <span asp-validation-for="TelescopioId" class="text-danger"></span>
            </div>

            @* --- Montura --- *@
            <div class="mb-3">
                <label asp-for="MonturaId" class="form-label fw-bold">Montura</label>
                <select asp-for="MonturaId" class="form-select equipo-select" data-aviso="aviso-montura">
                    <option value="">-- Seleccione una montura --</option>
                    @foreach (var m in Model.Monturas)
                    {
                        <option value="@m.Id">@m.Marca @m.Modelo — Stock: @m.Stock</option>
                    }
                </select>
                <div id="aviso-montura" class="mt-1"></div>
                <span asp-validation-for="MonturaId" class="text-danger"></span>
            </div>

            @* --- Cámara (opcional) --- *@
            <div class="mb-3">
                <label asp-for="CamaraId" class="form-label fw-bold">Cámara <small class="text-muted">(opcional)</small></label>
                <select asp-for="CamaraId" class="form-select equipo-select" data-aviso="aviso-camara">
                    <option value="">-- Sin cámara --</option>
                    @foreach (var c in Model.Camaras)
                    {
                        <option value="@c.Id">@c.Marca @c.Modelo — Stock: @c.Stock</option>
                    }
                </select>
                <div id="aviso-camara" class="mt-1"></div>
            </div>

            @* --- Ocular (opcional) --- *@
            <div class="mb-3">
                <label asp-for="OcularId" class="form-label fw-bold">Ocular <small class="text-muted">(opcional)</small></label>
                <select asp-for="OcularId" class="form-select equipo-select" data-aviso="aviso-ocular">
                    <option value="">-- Sin ocular --</option>
                    @foreach (var o in Model.Oculares)
                    {
                        <option value="@o.Id">@o.Marca @o.Modelo — Stock: @o.Stock</option>
                    }
                </select>
                <div id="aviso-ocular" class="mt-1"></div>
            </div>

            <p class="text-muted small">* Debe seleccionar al menos una cámara o un ocular.</p>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Registrar préstamo</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        /*
         * RF04: Verificación de disponibilidad del equipo en el cliente.
         * Al cambiar un selector de equipo, se consulta el endpoint WebAPI
         * GET /api/equipoapi/{id}/disponible via fetch (sin enviar el formulario).
         * Si el equipo no tiene stock, se muestra un aviso de alerta al usuario.
         *
         * Fuente: RF04 letra p.6 — "deberá resolverse del lado del cliente y la información
         * de si ese equipo está disponible deberá obtenerse consultando un endpoint WebAPI
         * mediante javascript."
         */
        document.querySelectorAll('.equipo-select').forEach(function (select) {
            select.addEventListener('change', function () {
                var equipoId = this.value;
                var avisoId = this.getAttribute('data-aviso');
                var avisoDiv = document.getElementById(avisoId);

                // Si no se seleccionó ningún equipo, limpiamos el aviso y salimos.
                if (!equipoId) {
                    avisoDiv.innerHTML = '';
                    return;
                }

                // Llamada al endpoint WebAPI para verificar disponibilidad.
                fetch('/api/equipoapi/' + equipoId + '/disponible')
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.disponible) {
                            // Hay stock: mostramos un badge verde informativo.
                            avisoDiv.innerHTML =
                                '<span class="badge bg-success">' + data.mensaje + '</span>';
                        } else {
                            // Sin stock: alerta naranja sin enviar el formulario.
                            avisoDiv.innerHTML =
                                '<div class="alert alert-warning py-1 mb-0">' +
                                '<strong>Sin disponibilidad:</strong> ' + data.mensaje +
                                '</div>';
                        }
                    })
                    .catch(function () {
                        avisoDiv.innerHTML =
                            '<span class="text-danger">Error al verificar disponibilidad</span>';
                    });
            });
        });
    </script>
}
